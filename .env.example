# =============================================================================
# ColorStack Fintech Workshop — copy variables into the right local files:
#   - Backend:  copy Flask lines → backend/.env
#   - Frontend: copy Vite line   → frontend/.env (optional)
# Never commit real .env files.
# =============================================================================

# --- Frontend (Vite) — optional; default API is http://localhost:5000
# VITE_API_BASE_URL=http://localhost:5000

# --- Backend (Flask) — workshop: no API keys required
# FRONTEND_URL=http://localhost:5173
# PORT=5000
# HISTORY_START_DATE=2016-01-01
# FLASK_SECRET_KEY=change_this_to_a_random_string

# --- Full version: Google OAuth (see backend/GOOGLE_OAUTH_SETUP.md)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5000/auth/callback
