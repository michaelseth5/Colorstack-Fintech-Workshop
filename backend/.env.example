# Copy to backend/.env for local overrides. Never commit backend/.env.
# Workshop: no Yahoo API key required (yfinance).

# FRONTEND_URL=http://localhost:5173
# PORT=5000
# HISTORY_START_DATE=2016-01-01
# FLASK_SECRET_KEY=change_this_to_a_random_string

# Google OAuth (full version — see GOOGLE_OAUTH_SETUP.md)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5000/auth/callback
