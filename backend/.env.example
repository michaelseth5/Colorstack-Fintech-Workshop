# --- Workshop version ---
# No API keys required. Optional: FRONTEND_URL for CORS if your Vite port differs.
# FRONTEND_URL=http://localhost:5173
# First calendar day of daily chart history (Yahoo); default 2016-01-01 (~2016–present).
# HISTORY_START_DATE=2016-01-01

# --- Full version: Google OAuth (uncomment in app.py + install requests) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5000/auth/callback
# When OAuth is re-enabled, set a strong random secret for session cookies:
# FLASK_SECRET_KEY=change_this_to_a_random_string
